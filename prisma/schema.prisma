// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ACCOUNT_TYPE {
  USER
  ADMIN
  FARMER
  AGENT
}

enum GENDER {
  M
  F
}

enum COUNTRY {
  NG
  GH
  ZA
  US
}

enum CURRENCY {
  NGN
  USD
  EUR
  GBP
}

enum TRANSACTION_CATEGORY {
  BILL_PAYMENT
  TRANSFER
  DEPOSIT
}

enum TRANSACTION_TYPE {
  DEBIT
  CREDIT
}

enum TRANSACTION_STATUS {
  pending
  success
  failed
}

enum TIER_LEVEL {
  notSet
  one
  two
  three
}

enum USER_ACCOUNT_STATUS {
  active
  restricted
  frozen
}

enum NETWORK {
  mtn
  airtel
  etisalat
  glo
}

enum USER_ROLE {
  USER
  ADMIN
  FARMER
  AGENT
}

enum INVITATION_STATUS {
  PENDING
  ACCEPTED
  EXPIRED
}

enum BILL_TYPE {
  data
  airtime
  internationalAirtime
  cable
  electricity
  internet
  transport
  schoolfee
  giftcard
}

enum SCAM_TICKET_STATUS {
  opened
  closed
}

enum BENEFICIARY_TYPE {
  TRANSFER
  BILL
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  email    String @unique
  username String @unique
  phoneNumber String @unique
  fullname String

  gender GENDER?

  country COUNTRY?

  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  currency                  CURRENCY @default(NGN)
  businessName              String?
  isBusiness                Boolean? @default(false)
  companyRegistrationNumber String?

  tokenVersion Int     @default(0)

  isPasscodeSet   Boolean @default(false)
  passcode        String?
  isPhoneVerified Boolean @default(false)
  isEmailVerified Boolean @default(false)
  isBvnVerified   Boolean @default(false)
  bvn             String?

  isNinVerified     Boolean      @default(false)
  isAddressVerified Boolean      @default(false)
  nin               String?
  address           String?
  state             String?
  city              String?
  selfieBase64Image String?
  accountType       ACCOUNT_TYPE @default(USER)

  walletPin      String?
  isWalletPinSet Boolean @default(false)

  profileImageFilename String?
  profileImageUrl      String?

  referralCode String?
  referredBy   String?

  scamTicketCount Int     @default(0)
  dateOfBirth     String?

  enabledTwoFa Boolean @default(true)

  status USER_ACCOUNT_STATUS @default(active)

  role                             USER_ROLE @default(USER)
  // transaction limit for user
  dailyCummulativeTransactionLimit Float     @default(0)
  cummulativeBalanceLimit          Float     @default(0)

  // tier level
  tierLevel TIER_LEVEL @default(notSet)

  // relationships
  wallet            Wallet[]
  beneficiaries     Beneficiary[]
  scamTicket        ScamTicket[]
  agentInvitations  AgentInvitation[]
  loanApplications  LoanApplication[] @relation("UserLoanApplications")
  agentApplications LoanApplication[] @relation("AgentLoanApplications")
  agentActivityLogs AgentActivityLog[]

  isBusinessRegistered Boolean @default(false)

  //table name
  @@map("users")
}

model Wallet {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @unique @db.Uuid
  balance  Float    @default(0)
  currency CURRENCY @default(NGN)

  accountNumber String   @unique
  accountName   String?
  bankName      String?
  bankCode      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accountRef String?

  // relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@index([accountNumber])
  @@map("wallet")
}

model Beneficiary {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  type BENEFICIARY_TYPE

  // details for transfer
  bankName      String?
  bankCode      String?
  accountNumber String?
  accountName   String?

  // details for bill payment
  network      NETWORK?
  billType     BILL_TYPE?
  billerNumber String?
  operatorId   Int?
  billerCode   String?
  itemCode     String?

  currency CURRENCY? @default(NGN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("beneficiary")
}

model Transaction {
  id       String @id @default(uuid()) @db.Uuid
  walletId String @db.Uuid

  transactionRef  String?
  type            TRANSACTION_TYPE
  category        TRANSACTION_CATEGORY @default(TRANSFER)
  currency        String
  status          TRANSACTION_STATUS   @default(pending)
  description     String?
  previousBalance Float
  currentBalance  Float

  reference String?

  billDetails     Json?
  transferDetails Json?
  depositDetails  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transaction")
}

model PaymentEvent {
  id String @id @default(uuid()) @db.Uuid

  refId    String
  status   String
  currency String?

  amountPaid       Float
  settlementAmount Float?
  fee              Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paymentEvent")
}

model AirtimePlan {
  id String @id @default(uuid()) @db.Uuid

  planName       String?
  network        NETWORK?
  countryISOCode String?
  operatorId     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("airtimePlan")
}

model DataPlan {
  id      String   @id @default(uuid()) @db.Uuid
  network NETWORK?

  planName       String?
  countryISOCode String?
  operatorId     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dataPlan")
}

model CablePlan {
  id String @id @default(uuid()) @db.Uuid

  planName       String?
  countryISOCode String?
  billerCode     String?
  description    String?
  shortName      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cablePlan")
}

model ElectricityPlan {
  id String @id @default(uuid()) @db.Uuid

  planName       String?
  countryISOCode String?
  billerCode     String?
  description    String?
  shortName      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("electricityPlan")
}

model InternetservicePlan {
  id String @id @default(uuid()) @db.Uuid

  planName       String?
  countryISOCode String?
  billerCode     String?
  description    String?
  shortName      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("internetservicePlan")
}

model TransportPlan {
  id String @id @default(uuid()) @db.Uuid

  planName       String?
  countryISOCode String?
  billerCode     String?
  description    String?
  shortName      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transportPlan")
}

model SchoolfeePlan {
  id String @id @default(uuid()) @db.Uuid

  planName       String?
  countryISOCode String?
  billerCode     String?
  description    String?
  shortName      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schoolfeePlan")
}

model ScamTicket {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @db.Uuid
  ref_number         Int
  title              String
  screenshotImageUrl String
  status             SCAM_TICKET_STATUS @default(opened)
  description        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ref_number])
  @@map("scamTicket")
}

model BankAccountCache {
  id             String   @id @default(uuid())
  accountNumber  String   @unique
  accountName    String?
  bankName       String?
  bankCode       String?
  routingKey     String?
  categoryId     String?
  verifiedAt     DateTime @default(now())
}

model BankNameCache {
  id        String   @id @default(uuid())
  bankCode  String   @unique
  bankName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([bankCode])
  @@index([bankName])
}

// ─── Loan Module Enums ───────────────────────────────────────────────────────

enum LOAN_APPLICATION_STATUS {
  Draft
  Submitted
  EligibilityReview
  PendingFieldVerification
  UnderReview
  MoreInfoRequired
  Approved
  Rejected
  FulfillmentInProgress
  ReadyForPickup
  OutForDelivery
  Delivered
  Active
  PartiallyRepaid
  Completed
  Overdue
  Cancelled
}

enum ELIGIBILITY_CHECK_RESULT {
  pass
  fail
  conditional
}

enum AGENT_RECOMMENDATION_TYPE {
  recommended
  not_recommended
  conditional
}

enum LOAN_DECISION_TYPE {
  approved
  rejected
  more_info_required
  hold
  send_for_verification
}

enum FULFILLMENT_STATUS {
  pending
  stock_confirmed
  packed
  dispatched
  delivered
}

enum REPAYMENT_STATUS {
  pending
  partial
  completed
  overdue
}

enum FARM_OWNERSHIP_TYPE {
  owned
  leased
  family_land
  cooperative_land
}

enum FULFILLMENT_METHOD {
  pickup
  delivery
}

enum MARKETPLACE_ORDER_STATUS {
  pending
  confirmed
  packed
  dispatched
  delivered
  cancelled
}

// ─── Loan Module Models ──────────────────────────────────────────────────────

model LoanResourceCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  resources LoanResource[]

  @@map("loan_resource_category")
}

model LoanResource {
  id          String  @id @default(uuid()) @db.Uuid
  categoryId  String  @db.Uuid
  name        String
  description String?
  imageUrl    String?

  unitPrice    Float
  unitOfMeasure String
  stockQuantity Float  @default(0)
  minQuantity   Float  @default(1)

  supplier    String?
  suitableCrops String?
  isEligibleForLoan Boolean @default(true)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category  LoanResourceCategory @relation(fields: [categoryId], references: [id])
  cartItems CartItem[]
  applicationItems LoanApplicationItem[]
  marketplaceOrderItems MarketplaceOrderItem[]

  @@index([categoryId])
  @@map("loan_resource")
}

model Farm {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  name     String
  address  String
  state    String
  lga      String
  ward     String?

  latitude  Float?
  longitude Float?

  sizeValue Float?
  sizeUnit  String?

  ownershipType FARM_OWNERSHIP_TYPE

  mainCropType      String
  secondaryCropType String?
  farmingSeason     String?
  expectedPlantingDate DateTime?
  expectedHarvestDate  DateTime?

  hasIrrigation Boolean @default(false)

  isVerified Boolean @default(false)
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  photos       FarmPhoto[]
  applications LoanApplication[]

  @@index([userId])
  @@map("farm")
}

model FarmPhoto {
  id        String   @id @default(uuid()) @db.Uuid
  farmId    String   @db.Uuid
  url       String
  filename  String?
  createdAt DateTime @default(now())

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@map("farm_photo")
}

model Supplier {
  id            String  @id @default(uuid()) @db.Uuid
  name          String
  location      String?
  contactPerson String?
  contactPhone  String?
  contactEmail  String?
  stockCapacity String?
  deliveryCoverage String?
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fulfillments      Fulfillment[]
  marketplaceOrders MarketplaceOrder[]

  @@map("supplier")
}

model Cart {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]

  @@map("cart")
}

model CartItem {
  id         String @id @default(uuid()) @db.Uuid
  cartId     String @db.Uuid
  resourceId String @db.Uuid
  quantity   Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart     Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  resource LoanResource @relation(fields: [resourceId], references: [id])

  @@unique([cartId, resourceId])
  @@map("cart_item")
}

model LoanApplication {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  farmId String @db.Uuid

  applicationRef String @unique

  status LOAN_APPLICATION_STATUS @default(Draft)

  purpose            String?
  season             String?
  expectedPlantingDate DateTime?
  expectedHarvestDate  DateTime?

  fulfillmentMethod  FULFILLMENT_METHOD?
  deliveryAddress    String?
  deliveryContact    String?

  agentId String? @db.Uuid

  totalEstimatedValue Float @default(0)
  currency            String @default("NGN")

  farmerNotes String?

  submittedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user             User                  @relation("UserLoanApplications", fields: [userId], references: [id])
  agent            User?                 @relation("AgentLoanApplications", fields: [agentId], references: [id])
  farm             Farm                  @relation(fields: [farmId], references: [id])
  items            LoanApplicationItem[]
  eligibilityChecks EligibilityCheck[]
  agentRecommendation AgentRecommendation?
  fieldVerification   FieldVerification?
  decisions        LoanDecision[]
  statusHistory    LoanStatusHistory[]
  fulfillment      Fulfillment?
  repaymentPlan    RepaymentPlan?
  auditLogs        LoanAuditLog[]
  marketplaceOrders MarketplaceOrder[]
  agentActivityLogs AgentActivityLog[]

  @@index([userId])
  @@index([status])
  @@index([applicationRef])
  @@map("loan_application")
}

model LoanApplicationItem {
  id            String @id @default(uuid()) @db.Uuid
  applicationId String @db.Uuid
  resourceId    String @db.Uuid

  itemName      String
  category      String?
  unitPrice     Float
  quantity      Float
  unitOfMeasure String
  totalAmount   Float
  supplier      String?

  approvedQuantity Float?
  approvedAmount   Float?

  createdAt DateTime @default(now())

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  resource    LoanResource    @relation(fields: [resourceId], references: [id])

  @@map("loan_application_item")
}

model EligibilityCheck {
  id            String @id @default(uuid()) @db.Uuid
  applicationId String @db.Uuid

  checkName  String
  result     ELIGIBILITY_CHECK_RESULT
  score      Float?
  note       String?
  source     String?
  isManual   Boolean  @default(false)
  checkedAt  DateTime @default(now())
  checkedBy  String?

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("eligibility_check")
}

model AgentRecommendation {
  id            String @id @default(uuid()) @db.Uuid
  applicationId String @unique @db.Uuid
  agentId       String @db.Uuid

  agentName       String?
  farmerKnown     Boolean @default(false)
  farmVisited     Boolean @default(false)
  visitDate       DateTime?
  farmExists      Boolean?
  cropConfirmed   Boolean?
  estimatedFarmSize Float?

  recommendation AGENT_RECOMMENDATION_TYPE
  note           String?
  photosUploaded String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("agent_recommendation")
}

model FieldVerification {
  id            String @id @default(uuid()) @db.Uuid
  applicationId String @unique @db.Uuid
  agentId       String @db.Uuid

  farmExists        Boolean?
  visitedAt         DateTime?
  cropConfirmed     Boolean?
  estimatedFarmSize Float?
  recommendation    AGENT_RECOMMENDATION_TYPE?
  note              String?
  photos            String[]

  createdAt DateTime @default(now())

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("field_verification")
}

model LoanDecision {
  id            String @id @default(uuid()) @db.Uuid
  applicationId String @db.Uuid
  decidedBy     String @db.Uuid

  decision LOAN_DECISION_TYPE
  reason   String?
  note     String?

  approvedTotalValue Float?
  repaymentTerms     Json?
  supplierId         String? @db.Uuid

  decidedAt DateTime @default(now())

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("loan_decision")
}

model LoanStatusHistory {
  id            String @id @default(uuid()) @db.Uuid
  applicationId String @db.Uuid

  fromStatus LOAN_APPLICATION_STATUS?
  toStatus   LOAN_APPLICATION_STATUS
  changedBy  String?
  reason     String?
  note       String?

  createdAt DateTime @default(now())

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("loan_status_history")
}

model LoanAuditLog {
  id            String @id @default(uuid()) @db.Uuid
  applicationId String @db.Uuid

  action        String
  performedById String?
  performedByRole String?
  details       Json?

  createdAt DateTime @default(now())

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("loan_audit_log")
}

model AgentActivityLog {
  id            String  @id @default(uuid()) @db.Uuid
  agentId       String  @db.Uuid
  action        String
  description   String
  metadata      Json?
  applicationId String? @db.Uuid

  createdAt DateTime @default(now())

  agent       User             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  application LoanApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([agentId, createdAt])
  @@map("agent_activity_log")
}

model Fulfillment {
  id            String @id @default(uuid()) @db.Uuid
  applicationId String @unique @db.Uuid
  supplierId    String? @db.Uuid

  fulfillmentRef    String?
  stockConfirmed    Boolean @default(false)
  deliveryMethod    FULFILLMENT_METHOD?
  pickupAddress     String?
  deliveryAddress   String?
  deliveryOfficer   String?
  deliveryPhone     String?
  receivedBy        String?
  deliveryProofUrl  String?
  deliveryNote      String?
  dispatchedAt      DateTime?
  deliveredAt       DateTime?

  status FULFILLMENT_STATUS @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  supplier    Supplier?       @relation(fields: [supplierId], references: [id])
  items       FulfillmentItem[]

  @@map("fulfillment")
}

model FulfillmentItem {
  id            String @id @default(uuid()) @db.Uuid
  fulfillmentId String @db.Uuid

  itemName       String
  quantity       Float
  unitOfMeasure  String
  stockAvailable Boolean @default(true)

  createdAt DateTime @default(now())

  fulfillment Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)

  @@map("fulfillment_item")
}

model RepaymentPlan {
  id            String @id @default(uuid()) @db.Uuid
  applicationId String @unique @db.Uuid

  principalEquivalent Float
  serviceCharge       Float  @default(0)
  totalRepaymentAmount Float
  repaymentFrequency  String
  numberOfInstallments Int
  installmentAmount   Float
  firstDueDate        DateTime
  lastDueDate         DateTime?

  amountRepaid     Float @default(0)
  outstandingBalance Float

  status REPAYMENT_STATUS @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  repayments  Repayment[]

  @@map("repayment_plan")
}

model Repayment {
  id              String @id @default(uuid()) @db.Uuid
  repaymentPlanId String @db.Uuid

  installmentNumber Int
  dueDate           DateTime
  amount            Float
  amountPaid        Float   @default(0)
  paidAt            DateTime?
  reference         String?
  note              String?

  status REPAYMENT_STATUS @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan RepaymentPlan @relation(fields: [repaymentPlanId], references: [id], onDelete: Cascade)

  @@index([repaymentPlanId])
  @@index([dueDate])
  @@map("repayment")
}

model LoanPolicy {
  id  String @id @default(uuid()) @db.Uuid

  maxLoanAmount        Float  @default(500000)
  maxItemQuantity      Float  @default(100)
  requireAgentReco     Boolean @default(false)
  allowResubmission    Boolean @default(true)
  repaymentFrequency   String  @default("monthly")
  defaultInstallments  Int     @default(6)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("loan_policy")
}

// ─── Marketplace Order Models ─────────────────────────────────────────────────

model MarketplaceOrder {
  id            String @id @default(uuid()) @db.Uuid
  applicationId String @db.Uuid
  userId        String @db.Uuid
  orderRef      String @unique

  totalAmount Float
  status      MARKETPLACE_ORDER_STATUS @default(pending)

  deliveryMethod  FULFILLMENT_METHOD?
  deliveryAddress String?
  deliveryContact String?
  pickupAddress   String?

  supplierId       String?   @db.Uuid
  dispatchedAt     DateTime?
  deliveredAt      DateTime?
  receivedBy       String?
  deliveryProofUrl String?
  deliveryNote     String?
  adminNote        String?

  cancelledAt  DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application LoanApplication      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  supplier    Supplier?            @relation(fields: [supplierId], references: [id])
  items       MarketplaceOrderItem[]

  @@index([applicationId])
  @@index([userId])
  @@map("marketplace_order")
}

model MarketplaceOrderItem {
  id         String @id @default(uuid()) @db.Uuid
  orderId    String @db.Uuid
  resourceId String @db.Uuid

  itemName      String
  category      String?
  unitPrice     Float
  quantity      Float
  unitOfMeasure String
  totalAmount   Float
  supplier      String?

  createdAt DateTime @default(now())

  order    MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  resource LoanResource     @relation(fields: [resourceId], references: [id])

  @@index([orderId])
  @@map("marketplace_order_item")
}


model AgentInvitation {
  id          String            @id @default(uuid()) @db.Uuid
  email       String
  token       String            @unique
  status      INVITATION_STATUS @default(PENDING)
  expiresAt   DateTime
  usedAt      DateTime?
  invitedById String            @db.Uuid

  invitedBy User @relation(fields: [invitedById], references: [id])

  createdAt DateTime @default(now())

  @@map("agent_invitations")
}

model Tier {
  id                  String     @id @default(uuid()) @db.Uuid
  level               TIER_LEVEL @unique
  name                String
  kycLevel            Int
  dailyLimit          Float
  perTransactionLimit Float
  walletLimit         Float
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@map("tier")
}
