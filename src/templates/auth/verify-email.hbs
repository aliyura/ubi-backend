<html lang='en'>

<head>
  <meta charset='UTF-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1.0' />
  <title>Verification Code</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family:
        -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu,
        Cantarell, sans-serif;
    }

    body {
      background-color: #f5f5f5;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .verification-card {
      background: #ffff;
      color: black;
      border-radius: 12px;
      padding: 32px;
      max-width: 400px;
      width: 100%;
      text-align: center;
    }

    .shield-icon {
      width: 64px;
      height: 64px;
      margin-bottom: 16px;
      fill: #f76301;
    }

    .title {
      color: white;
      font-size: 24px;
      margin-bottom: 8px;
    }

    .subtitle {
      color: rgba(255, 255, 255, 0.7);
      font-size: 12px;
      margin-bottom: 24px;
    }

    .instructions {
      font-size: 14px;
      line-height: 1.5;
      margin-top: 24px;
      margin-bottom: 24px;
      text-align: start;
    }

    .instructions-header {
      font-size: 20px;
    }

    .responsive-img {
      width: 100%;
      height: auto;
    }

    .code-container {
      background: #f76301;
      padding: 20px;
      border-radius: 8px;
      margin: 24px 0;
    }

    .code-label {
      color: black;
      font-size: 16px;
      margin-bottom: 8px;
    }

    .code {
      color: black;
      font-size: 28px;
      font-weight: bold;
      letter-spacing: 2px;
    }

    .support-info {
      font-size: 14px;
      margin: 24px 0;
    }

    .support-link {
      color: #f76301;
      text-decoration: none;
      font-weight: 500;
      display: inline-block;
      margin: 4px 0;
    }

    .footer {
      font-size: 12px;
      margin-top: 24px;
    }
  </style>
</head>

<body>
  <div class='verification-card'>
    <img src='https://res.cloudinary.com/dyklkieao/image/upload/v1743937534/ubi/hero-ubi_g92qho.png' alt='img'
      class='responsive-img' />

    <div class='instructions'>
      <h1 class='instructions-header'>Complete Your Verification</h1>
      <p>
        Please enter this 6-digit Confirmation code to verify your UBI
        account. If you did not request this, please reach out to us via
        WhatsApp or send a message to our support email
      </p>
    </div>

    <div class='code-container'>
      <div class='code-label'>Verification Code</div>
      <div class='code'>{{otpCode}}</div>
    </div>

    <div class='support-info'>
      If you experience any problems kindly contact us at<br />
      <a href='mailto:support@ubi.com' class='support-link'>support@ubi.com</a>
      <br />or send us a WhatsApp message at<br />
      <a href='tel:+234-813-414-6906' class='support-link'>+234-813-414-6906</a>
    </div>

    <div class='footer'>© All Right Reserved by UBI {{year}}</div>
  </div>
</body>

</html>