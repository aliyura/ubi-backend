<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>#{{ticketId}} Ticket Created - {{title}}</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
        background-color: #fffbe6; /* Subtle gold background */
        color: #333;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
      }
      .container {
        background-color: #fff;
        border: 2px solid #046307;
        /* Gold border */
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        max-width: 500px;
        padding: 20px;
        text-align: center;
      }
      .header {
        font-size: 24px;
        font-weight: bold;
        color: #ff8c00; /* Gold text */
      }
      .icon {
        font-size: 50px;
        color: #046307; /* Gold icon */
        margin-bottom: 15px;
      }
      .message {
        font-size: 18px;
        margin-bottom: 20px;
        line-height: 1.6;
      }
      .ticket-info {
        background-color: #ffeb99; /* Light gold highlight */
        padding: 10px;
        border-radius: 5px;
        font-weight: bold;
        color: #ff8c00;
        margin-bottom: 20px;
      }
      .cta-button {
        display: inline-block;
        text-decoration: none;
        background-color: #046307;
        color: #fff;
        font-weight: bold;
        padding: 10px 20px;
        border-radius: 5px;
        transition: background-color 0.3s;
      }
      .cta-button:hover {
        background-color: #e07200;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='icon'>✔️</div>
      <div class='header'>Report Submitted Successfully</div>
      <p class='message'>
        Thank you for helping us maintain a safe financial environment. Your
        report has been successfully created, and our team will review it
        shortly.
      </p>
      <div class='ticket-info'>
        Ticket ID:
        {{ticketId}}<br />
        Submitted:
        {{submissionDate}}
      </div>
    </div>
  </body>
</html>